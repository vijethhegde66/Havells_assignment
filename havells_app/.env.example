
# Azure OpenAI Configuration
# Replace these with your actual Azure OpenAI credentials
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Azure AD Authentication (if using Azure AD instead of API key)
TECHDEMO_TENANT_ID=your_tenant_id_here
TECHDEMO_CLIENT_ID=your_client_id_here
TECHDEMO_CLIENT_SECRET=your_client_secret_here

# Model Configuration
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# Reset Detection Configuration
RESET_LATENCY_BUDGET_MS=500
RESET_ENABLE_LOGGING=true

# Application Settings
LOG_LEVEL=INFO
